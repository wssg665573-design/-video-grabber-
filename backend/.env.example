# VideoGrab 配置文件（部署时把 .env.example 复制成 .env 即可）

# 启用 API Key 鉴权：留空表示不启用（开放模式）
API_KEY=

# 站点公网 URL（用于 robots.txt 中的 sitemap 与绝对链接，可留空）
PUBLIC_BASE_URL=

# 允许的跨域来源（逗号分隔，* 表示全部）
ALLOW_ORIGINS=*

# 单次请求最大 URL 数
MAX_BATCH=20

# 单文件最大字节数（默认 200MB）
MAX_FILE_BYTES=209715200

# 服务监听端口
PORT=8000

# 工作进程数（容器内建议 2）
WORKERS=2

# 日志级别
LOG_LEVEL=INFO
